---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Steven Mendez's Portfolio">
  <main>
    <header class="header-section">
      <h1>Welcome to my Portfolio</h1>
    </header>
  </main>
</Layout>

<style>
  :root {
    --header-padding-small: 20px;
    --header-padding-large: 32px;
    --mask-image: radial-gradient(rgba(0, 0, 0, 0.45), transparent 70%);
  }

  .header-section {
    /* Apply flexbox layout to center the content */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: visible;
    text-align: center;
    padding-top: var(--header-padding-small);
  }

  @media (min-width: 640px) {
    .header-section {
      padding-top: var(--header-padding-small);
    }
  }

  @media (min-width: 1024px) {
    .header-section {
      padding-top: var(--header-padding-large);
    }
  }

  .header-section::before {
    content: '';
    position: absolute;
    z-index: -1;
    top: 0%;
    bottom: 10%;
    width: 150%;
    left: -25%;
    background: var(--color-background-gradient);
    -webkit-mask-image: var(--mask-image);
    mask-image: var(--mask-image);
  }
</style>

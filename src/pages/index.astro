---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Steven Mendez's Portfolio">
  <main>
    <header class="header-section">
      <h1 class="portfolio-title">
        Steven Mendez <span class="gradient-text"
          >Software Backend Developer</span
        >
      </h1>
      <p class="text">
        Hey there! 👋 Check out my portfolio! I specialize in building reliable
        and efficient backend solutions. Let's explore the exciting intersection
        of curiosity and coding together! 🚀
      </p>
    </header>
  </main>
</Layout>

<style>
  :root {
    --header-padding-small: 20px;
    --header-padding-large: 32px;
    --mask-image: radial-gradient(rgba(0, 0, 0, 0.45), transparent 70%);
  }

  .header-section {
    /* Apply flexbox layout to center the content */
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-top: var(--header-padding-small);
    height: 100vh;
  }

  .header-section::before {
    content: '';
    position: absolute;
    top: 0%;
    bottom: 10%;
    width: 150%;
    left: -25%;
    background: var(--color-background-gradient);
    -webkit-mask-image: var(--mask-image);
    mask-image: var(--mask-image);
    z-index: -1;
  }

  .portfolio-title {
    margin-bottom: 1.5rem;
    max-width: 700px;
    padding-left: 1rem;
    padding-right: 1rem;
    text-align: left;
    font-family: 'Obviously', sans-serif;
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 0.8;
  }

  @media (min-width: 768px) {
    .portfolio-title {
      font-size: 3rem;
    }
  }

  .gradient-text {
    background: -webkit-linear-gradient(45deg, #40cfff 0%, #fdf48e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 1.9rem;
  }

  .text {
    padding-left: 1rem;
    padding-right: 1rem;
    max-width: 700px;
    text-align: left;
  }

  @media (max-width: 768px) {
    .portfolio-title {
      font-size: 2.5rem;
    }

    .gradient-text {
      font-size: 1.9rem;
    }

    .text {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 576px) {
    .header-section {
      padding-top: var(--header-padding-large);
    }

    .portfolio-title {
      font-size: 2.2rem;
    }

    .gradient-text {
      font-size: 1.6rem;
    }

    .text {
      font-size: 1.2rem;
    }
  }
</style>
